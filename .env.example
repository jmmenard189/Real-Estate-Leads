# ============================================================
# GTA Home Search — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ---- DATABASE (required) ----
DATABASE_URL=postgresql://user:password@host:5432/database

# ---- SESSION (required) ----
SESSION_SECRET=change-this-to-a-long-random-string

# ---- CRM: Follow Up Boss (optional) ----
# Get your API key from Follow Up Boss > Admin > API
FOLLOW_UP_BOSS_API_KEY=
# System name tag applied to all leads (default: mygtahomesearch)
FOLLOW_UP_BOSS_SYSTEM=mygtahomesearch

# ---- CRM: Webhook / Zapier (optional) ----
# Paste your Zapier, Make, or custom webhook URL here
WEBHOOK_URL=

# ---- CRM: Email fallback (optional) ----
# Email address to receive lead notifications
NOTIFICATION_EMAIL=

# ---- IDX (future — do not add yet) ----
# IDX_API_KEY=
# IDX_API_SECRET=
# IDX_PROVIDER=
